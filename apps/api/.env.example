DB_URL=<MySQL 접속 URL 예: jdbc:mysql://localhost:3306/데이터베이스명?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC>
DB_USERNAME=<MySQL 사용자 이름>
DB_PASSWORD=<MySQL 사용자 비밀번호>

REDIS_HOST=<Redis 서버 주소 예: localhost>
REDIS_PORT=<Redis 포트 번호 예: 6379>

FRONTEND_URL=<프론트엔드 주소 예: [http://localhost:3000>](http://localhost:3000>)

ADMIN_EMAIL=<초기 관리자 이메일>
ADMIN_PASSWORD=<초기 관리자 비밀번호>
ADMIN_DISPLAY_NAME=<초기 관리자 표시 이름>

JWT_SECRET=<JWT 서명에 사용할 비밀 키>
JWT_ACCESS_TOKEN_MINUTES=<Access Token 만료 시간, 분 단위>
JWT_REFRESH_TOKEN_DAYS=<Refresh Token 만료 기간, 일 단위>

AWS_REGION=<AWS 리전 예: ap-northeast-2>
MEDIA_S3_BUCKET=<미디어 파일을 저장할 S3 버킷 이름>
MEDIA_S3_PREFIX=<S3 안에서 업로드 파일을 저장할 경로 prefix 예: uploads/media>
MEDIA_STORAGE_MODE=<미디어 저장 방식 예: s3 또는 local>
MEDIA_MAX_UPLOAD_BYTES=<최대 업로드 파일 크기, byte 단위>

CLOUDFRONT_BASE_URL=<CloudFront 배포 도메인 URL>

GOOGLE_CLIENT_ID=<Google OAuth Client ID>
GOOGLE_CLIENT_SECRET=<Google OAuth Client Secret>

KAKAO_CLIENT_ID=<Kakao OAuth Client ID>
KAKAO_CLIENT_SECRET=<Kakao OAuth Client Secret>
